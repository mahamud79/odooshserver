<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="partner_portal_public_landing" name="Partner Portal Landing (Public)">
            <t t-call="website.layout">
                <div class="container my-5">
                    <div class="row justify-content-center">
                        <div class="col-12 col-lg-8">
                            <div class="card shadow-sm">
                                <div class="card-body p-4">
                                    <h1 class="h3 mb-2">Partner Portal</h1>
                                    <p class="text-muted mb-3">
                                        Please sign in with your portal account to access your partner dashboard.
                                    </p>
                                    <a class="btn btn-primary" href="/web/login">Sign in</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>

        <template id="portal_my_home_inherit_partner" inherit_id="portal.portal_my_home" name="Portal Home Partner Link">
            <xpath expr="//div[contains(@class,'o_portal_docs')]" position="inside">
                <a class="btn btn-outline-primary me-2 mb-2" href="/partners/portal">
                    Partner Portal
                </a>
            </xpath>
        </template>

        <template id="portal_partner_dashboard" name="Partner Portal Dashboard">
            <t t-call="portal.portal_layout">
                <t t-set="breadcrumbs_searchbar" t-value="True"/>
                <div class="container o_portal_wrap py-4">
                    <div t-if="success_message" class="alert alert-success"><t t-esc="success_message"/></div>
                    
                    <h1 class="mb-3">Partner Portal</h1>

                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <div class="card h-100" id="portal_partner_profile_card">
                                <div class="card-body">
                                    <h5 class="card-title">Profile &amp; Attribution</h5>
                                    <div><strong>Name:</strong> <span t-esc="partner.name"/></div>
                                    <div><strong>Email:</strong> <span t-esc="partner.email or ''"/></div>
                                    <div><strong>Phone:</strong> <span t-esc="partner.phone or ''"/></div>
                                    
                                    <hr class="my-2"/>
                                    
                                    <div class="mt-2"><strong>Role:</strong> <span t-esc="role_label or partner.partner_role"/></div>
                                    <t t-if="partner.partner_uid">
                                        <div class="mt-1"><strong>Partner ID:</strong> <span t-esc="partner.partner_uid"/></div>
                                    </t>
                                    <t t-if="partner.partner_code">
                                        <div class="mt-1"><strong>Partner Code:</strong> <span t-esc="partner.partner_code"/></div>
                                    </t>

                                    <t t-if="role in ['lead', 'ap', 'sales_agent']">
                                        <div class="mt-3">
                                            <a href="/partners/portal/leads" class="btn btn-success w-100">
                                                <i class="fa fa-plus-circle me-1"/> Submit New Lead
                                            </a>
                                        </div>
                                    </t>
                                    
                                    <div class="mt-2 text-muted small">
                                        <i class="fa fa-info-circle me-1"/>
                                        Your account is restricted to codes-only attribution. Cookies and referral tracking are disabled.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">Compliance (KYC)</h5>
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        <span class="badge text-bg-secondary">
                                            KYC: <t t-esc="partner.kyc_status or 'Not Submitted'"/>
                                        </span>
                                        <t t-if="partner.bank_verified">
                                            <span class="badge text-bg-success">Bank Verified</span>
                                        </t>
                                        <t t-else="">
                                            <span class="badge text-bg-warning">Bank Not Verified</span>
                                        </t>
                                        <t t-if="partner.kyc_blocked">
                                            <span class="badge text-bg-danger">Blocked</span>
                                        </t>
                                    </div>
                                    <t t-if="partner.kyc_verified_on">
                                        <div class="mb-2">
                                            <strong>Verified On:</strong>
                                            <span t-field="partner.kyc_verified_on" t-options='{"widget": "date"}'/>
                                        </div>
                                    </t>
                                    <div class="mb-2">
                                        <strong>Missing Items:</strong>
                                        <span class="text-danger" t-esc="partner.compliance_missing or 'None'"/>
                                    </div>
                                    <div class="d-flex flex-wrap gap-2 mt-3">
                                        <a class="btn btn-primary btn-sm" href="/partners/portal/kyc">Update KYC</a>
                                        <a class="btn btn-outline-secondary btn-sm" href="/partners/portal/contracts">Contracts</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-3">
                                <div class="col-12 col-md-4">
                                    <div class="card h-100 border-start border-info border-4">
                                        <div class="card-body">
                                            <div class="text-muted small">On Hold</div>
                                            <div class="fs-4 fw-semibold">
                                                <t t-esc="(partner.company_id.currency_id.symbol) or ''"/>
                                                <t t-esc="('%.2f' % (on_hold_amount or 0.0))"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-4">
                                    <div class="card h-100 border-start border-primary border-4">
                                        <div class="card-body">
                                            <div class="text-muted small">Payable</div>
                                            <div class="fs-4 fw-semibold">
                                                <t t-esc="(partner.company_id.currency_id.symbol) or ''"/>
                                                <t t-esc="('%.2f' % (payable_amount or 0.0))"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-4">
                                    <div class="card h-100 border-start border-success border-4">
                                        <div class="card-body">
                                            <div class="text-muted small">Total Paid</div>
                                            <div class="fs-4 fw-semibold">
                                                <t t-esc="(partner.company_id.currency_id.symbol) or ''"/>
                                                <t t-esc="('%.2f' % (paid_amount or 0.0))"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">Documents</h5>
                                    <form action="/partners/portal/documents/upload" method="post" enctype="multipart/form-data" class="mb-3">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="d-flex gap-2 flex-wrap align-items-center">
                                            <input class="form-control w-auto" type="file" name="document" required="required"/>
                                            <button class="btn btn-outline-primary" type="submit">Upload</button>
                                        </div>
                                    </form>
                                    <t t-if="partner_docs">
                                        <div class="list-group">
                                            <t t-foreach="partner_docs" t-as="d">
                                                <t t-set="dl_url" t-value="'/web/content/%s?download=true%s' % (d.id, (d.access_token and ('&amp;access_token=%s' % d.access_token)) or '')"/>
                                                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" t-att-href="dl_url" target="_blank">
                                                    <span><t t-esc="d.name"/></span>
                                                    <span class="text-muted small">Download <i class="fa fa-download ms-1"/></span>
                                                </a>
                                            </t>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="alert alert-light border mb-0 text-center">No documents uploaded yet.</div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>
