<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document_inherit_partner_attribution_v1" inherit_id="account.report_invoice_document">
        
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-if="o.attributed_partner_id">
                <div class="row mt-5 mb-4" id="partner_attribution_info" style="page-break-inside: avoid;">
                    <div class="col-12" style="border-top: 1px solid #ddd; padding-top: 15px;">
                        <strong>Attributed Partner: </strong>
                        <span t-field="o.attributed_partner_id"/><br/>
                        
                        <t t-if="o.attribution_locked">
                            <strong>Attribution Locked: </strong> Yes<br/>
                            
                            <t t-if="o.attribution_locked_at">
                                <strong>Locked At: </strong> 
                                <span t-field="o.attribution_locked_at" t-options='{"widget":"datetime"}'/><br/>
                            </t>
                            
                            <t t-if="o.attribution_locked_by">
                                <strong>Locked By: </strong> 
                                <span t-field="o.attribution_locked_by"/><br/>
                            </t>
                        </t>
                    </div>
                </div>
            </t>
        </xpath>
        
    </template>
</odoo>
